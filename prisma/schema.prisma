generator client {
  provider = "prisma-client-js"
}

generator typegraphql {
  provider = "typegraphql-prisma"
  output   = "../generated/type-graphql" // Set the output to a directory outside node_modules
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

